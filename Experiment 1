#include <stdio.h>
#include <ctype.h>
#include <string.h>

int isKeyword(char *str) 
{
    char *keywords[] = {"int","float","if","else","while","return","for","char"};
    for(int i=0;i<8;i++) 
	{
        if(strcmp(str, keywords[i])==0)
            return 1;
    }
    return 0;
}

int main() 
{
    char str[100], token[50];
    int i=0, j=0;

    printf("Enter code: ");
    gets(str);

    while(str[i] != '\0') 
	{
        if(isalnum(str[i])) 
		{
            token[j++] = str[i];
        }
        else 
		{
            if(j>0) 
			{
                token[j]='\0';
                if(isKeyword(token))
                    printf("%s : Keyword\n", token);
                else
                    printf("%s : Identifier\n", token);
                j=0;
            }
            if(str[i]=='+'||str[i]=='-'||str[i]=='*'||str[i]=='/')
                printf("%c : Operator\n", str[i]);
        }
        i++;
    }
    return 0;
}
