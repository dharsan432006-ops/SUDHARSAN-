#include<stdio.h>
#include<string.h>
#include<ctype.h>

char production[10][10];
char first[10];
char follow[10];
int n;

void find_first(char c) {
    if(!isupper(c)) {
        printf("%c ", c);
        return;
    }
    for(int i=0;i<n;i++) {
        if(production[i][0]==c) {
            if(production[i][2]=='$')
                printf("$ ");
            else if(!isupper(production[i][2]))
                printf("%c ", production[i][2]);
            else
                find_first(production[i][2]);
        }
    }
}

int main() {
    int i;
    char c;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%s",production[i]);

    printf("Enter symbol to find FIRST: ");
    scanf(" %c",&c);
    find_first(c);

    return 0;
}
